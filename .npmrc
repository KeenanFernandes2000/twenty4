# Pin ONE physical copy of drizzle-orm across workspaces.
# Better Auth (M2) pulls kysely, which historically split drizzle-orm into two
# physical copies → incompatible PgColumn types. The kysely devDep on
# @twenty4/contracts + this flag keep everything on a single copy. Baked in at M0
# (before auth) on purpose. See PHASE1_WORK_RECAP.md §5 / §8.1.
dedupe-peer-dependents=false

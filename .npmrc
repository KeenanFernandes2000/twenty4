# Keep peer-dependent variants from being merged, so `services/api` resolves the
# same `drizzle-orm` physical copy as `@twenty4/contracts` (both postgres-flavored)
# instead of better-auth's kysely+postgres-merged variant. Without this, two
# nominally-incompatible drizzle-orm copies leak into the API's db/table types.
dedupe-peer-dependents=false

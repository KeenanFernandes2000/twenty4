{
  "name": "twenty4",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "services/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "bun run --cwd services/api dev",
    "dev:api": "bun run --cwd services/api dev",
    "db:generate": "bun run --cwd packages/contracts db:generate",
    "db:migrate": "bun run --cwd packages/contracts db:migrate",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "bun test"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@twenty4/config": "workspace:*",
    "@types/bun": "^1.3.12",
    "eslint": "^9.39.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4"
  }
}

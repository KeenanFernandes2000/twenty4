  },
  "dependencies": {
    "@twenty4/contracts": "workspace:*",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "remotion": "4.0.481",
    "zod": "^3.23"
  },
  "devDependencies": {
    "@remotion/cli": "4.0.481",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "typescript": "^5.6.0"
  }
}

# twenty4 — environment template. Copy to .env for local runs:  cp .env.example .env
# (.env is gitignored.) Values below match docker-compose.yml defaults.

# ─────────────────────────── Database (Postgres 16) ───────────────────────────
# Host port 5433 (compose maps 5433->container 5432): avoids a Windows-side
# Postgres that shadows localhost:5432 under Docker Desktop + WSL2.
DATABASE_URL=postgres://twenty4:twenty4@localhost:5433/twenty4

# ─────────────────────────── Redis 7 ─────────────────────────────────────────
# Host port 6380 (compose maps 6380->container 6379): avoids a native/Windows
# Redis shadowing localhost:6379.
REDIS_URL=redis://localhost:6380

# ─────────────────────────── Object storage (MinIO / S3) ─────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_BUCKET_RAW=raw
S3_BUCKET_MONTAGES=montages
S3_BUCKET_THUMBNAILS=thumbnails

# ─────────────────────────── Media presign (M4) ──────────────────────────────
# THE v1 lesson: SigV4 signs the Host header, so a presigned URL signed against
# localhost is unusable from the phone. The S3 client that SIGNS presigned PUT/GET
# URLs uses S3_PUBLIC_ENDPOINT (the LAN/Tailscale host reachable from BOTH host
# AND device); server-side ops (HeadObject/DeleteObject) use S3_ENDPOINT above.
# Set to the machine's LAN/Tailscale IP (e.g. http://100.98.100.117:9000).
# NOTE: S3_BUCKET_RAW (`raw`) is the spec's "raw-media" bucket (reused from M0).
S3_PUBLIC_ENDPOINT=http://100.98.100.117:9000
# Presigned-URL TTLs (seconds) + raw-media safety-backstop TTL (hours).
MEDIA_UPLOAD_URL_TTL_SEC=900
MEDIA_DOWNLOAD_URL_TTL_SEC=900
MEDIA_RAW_TTL_HOURS=26

# ─────────────────────────── API server ──────────────────────────────────────
# Bind 0.0.0.0 so a real device on the LAN/Tailscale net can reach it.
API_HOST=0.0.0.0
API_PORT=3000

# ─────────────────────────── Mobile (Expo) ───────────────────────────────────
# Set to the machine's LAN/Tailscale IP (e.g. http://100.98.100.117:3000), NOT 127.0.0.1.
# 127.0.0.1 is loopback-only and unreachable from the phone. See RUNNING.md.
EXPO_PUBLIC_API_URL=http://100.98.100.117:3000

# ─────────────────────────── Email (dev: Mailpit) ────────────────────────────
# M2 email-OTP dev transport captures mail in Mailpit (web UI http://localhost:8025).
MAILPIT_HOST=localhost
MAILPIT_PORT=1025

# ─────────────────────────── Email (prod: SES) ───────────────────────────────
# Uncomment for production. The Mailpit -> SES swap is NODE_ENV-switched in app code.
# SES_FROM_EMAIL=no-reply@twenty4.app
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# ─────────────────────────── Auth (M2 — Better Auth + OTP) ───────────────────
# Dev signing secret. The prod-secret guard rejects this placeholder under
# NODE_ENV=production (must set a real one for prod).
BETTER_AUTH_SECRET=dev-better-auth-secret-change-me
# Comma-separated emails seeded to is_admin=true (account-create + boot reconcile).
ADMIN_EMAILS=admin@twenty4.app
# OTP throttle caps (env-configurable for deterministic CI).
OTP_MAX_PER_IP=20
OTP_MAX_PER_IDENTIFIER=5
OTP_WINDOW_SEC=900
OTP_VERIFY_MAX_ATTEMPTS=5
# Optional: force-enable/disable the dev /auth/dev/last-otp route (default: on when
# NODE_ENV!=='production'). Set false to double-gate a prod-like staging env.
# ENABLE_DEV_OTP_ROUTE=true
# Invite throttle caps (M3) — per-user fixed-window caps on invite create + join.
INVITE_CREATE_CAP=30
INVITE_JOIN_CAP=60
INVITE_WINDOW_SEC=900

# =============================================================================
# twenty4 — environment variables
# -----------------------------------------------------------------------------
# Placeholders only. Real local values live in ~/.twenty4-dev-env.sh (sourced
# into your shell). Copy to .env for local dev, or export the vars yourself.
# Defaults below assume the local docker-compose.dev.yml stack.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL 16, citext-enabled)
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://twenty4@127.0.0.1:5432/twenty4

# -----------------------------------------------------------------------------
# Redis (BullMQ queue + cache)
# -----------------------------------------------------------------------------
REDIS_URL=redis://127.0.0.1:6379

# -----------------------------------------------------------------------------
# Object storage (S3-compatible: MinIO local / R2|S3 prod)
# Signed URLs only — no public read.
# -----------------------------------------------------------------------------
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
# MinIO/R2 require path-style addressing; set false for AWS S3 virtual-hosted.
S3_FORCE_PATH_STYLE=true
# Bucket map: raw uploads | rendered montages | thumbnails
S3_BUCKET_RAW=raw
S3_BUCKET_MONTAGES=montages
S3_BUCKET_THUMBNAILS=thumbnails

# -----------------------------------------------------------------------------
# Media tooling (worker) — ffmpeg/ffprobe binaries
# Leave blank to use PATH; Dockerfile.worker installs system ffmpeg.
# -----------------------------------------------------------------------------
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# -----------------------------------------------------------------------------
# API server (Fastify)
# -----------------------------------------------------------------------------
PORT=3000
HOST=0.0.0.0

# -----------------------------------------------------------------------------
# Auth (Better Auth 1.6)
# BETTER_AUTH_SECRET: 32+ byte random string (e.g. `openssl rand -base64 32`).
# -----------------------------------------------------------------------------
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_URL=http://127.0.0.1:3000

# -----------------------------------------------------------------------------
# App behavior / business rules
# -----------------------------------------------------------------------------
# 4am→4am day window: floor((utc − DAY_WINDOW_OFFSET_HOURS) in device tz).
DAY_WINDOW_OFFSET_HOURS=4

# -----------------------------------------------------------------------------
# Signed-URL TTL defaults (seconds). Effective TTL = min(default, remaining
# content lifetime) so leaked URLs 404 once content is deleted.
# -----------------------------------------------------------------------------
SIGNED_URL_TTL_PUT=900
SIGNED_URL_GET_TTL=3600

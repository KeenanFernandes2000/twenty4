# twenty4 — environment template. Copy to .env for local runs:  cp .env.example .env
# (.env is gitignored.) Values below match docker-compose.yml defaults.

# ─────────────────────────── Database (Postgres 16) ───────────────────────────
# Host port 5433 (compose maps 5433->container 5432): avoids a Windows-side
# Postgres that shadows localhost:5432 under Docker Desktop + WSL2.
DATABASE_URL=postgres://twenty4:twenty4@localhost:5433/twenty4

# ─────────────────────────── Redis 7 ─────────────────────────────────────────
# Host port 6380 (compose maps 6380->container 6379): avoids a native/Windows
# Redis shadowing localhost:6379.
REDIS_URL=redis://localhost:6380

# ─────────────────────────── Object storage (MinIO / S3) ─────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_BUCKET_RAW=raw
S3_BUCKET_MONTAGES=montages
S3_BUCKET_THUMBNAILS=thumbnails

# ─────────────────────────── API server ──────────────────────────────────────
# Bind 0.0.0.0 so a real device on the LAN/Tailscale net can reach it.
API_HOST=0.0.0.0
API_PORT=3000

# ─────────────────────────── Mobile (Expo) ───────────────────────────────────
# Set to the machine's LAN/Tailscale IP (e.g. http://100.98.100.117:3000), NOT 127.0.0.1.
# 127.0.0.1 is loopback-only and unreachable from the phone. See RUNNING.md.
EXPO_PUBLIC_API_URL=http://100.98.100.117:3000

# ─────────────────────────── Email (dev: Mailpit) ────────────────────────────
# M2 email-OTP dev transport captures mail in Mailpit (web UI http://localhost:8025).
MAILPIT_HOST=localhost
MAILPIT_PORT=1025

# ─────────────────────────── Email (prod: SES) ───────────────────────────────
# Uncomment for production. The Mailpit -> SES swap is NODE_ENV-switched in app code.
# SES_FROM_EMAIL=no-reply@twenty4.app
# AWS_REGION=us-east-1

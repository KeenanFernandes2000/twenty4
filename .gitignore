# ───────────────────────── Dependencies ─────────────────────────
node_modules/
.pnp
.pnp.*
jspm_packages/

# ───────────────────────── Build output ─────────────────────────
dist/
build/
# NOTE: keep build-output patterns anchored to avoid matching src/lib, src/build, etc.
*.tsbuildinfo
.tsbuildinfo

# ───────────────────────── Monorepo tooling ─────────────────────
.turbo/
.cache/

# ───────────────────────── Bun ──────────────────────────────────
# NOTE: bun.lockb IS committed — do not ignore it.
.bun/

# ───────────────────────── Expo / React Native (apps/mobile) ────
.expo/
.expo-shared/
*.expo/
web-build/
# Generated native projects (expo prebuild / run:android)
apps/mobile/android/
apps/mobile/ios/
# Expo / EAS local artifacts
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*

# ───────────────────────── Remotion / render workers ───────────
# Local render + validation artifacts (infra/remotion, services/worker)
.smoke-out/
.gate-out/
.harness-out/
out-render/
remotion-renders/

# ───────────────────────── Local infra data ────────────────────
# Postgres / Redis / MinIO local data dirs (no Docker — runs on host)
infra/**/data/
*.pid
*.sock

# ───────────────────────── Environment ─────────────────────────
.env
.env.*
!.env.example
!.env.sample

# ───────────────────────── Sample-media fixtures ───────────────
# Folder is git-tracked; contents gitignored except the README.
# Used by M6 (import) and M7 (render gate).
fixtures/sample-media/*
!fixtures/sample-media/README.md

# ───────────────────────── Logs ────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ───────────────────────── Test / coverage ─────────────────────
coverage/
.nyc_output/
*.lcov

# ───────────────────────── Editors / IDEs ──────────────────────
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.history/

# ───────────────────────── OS cruft ────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
graphify-out/

# ───────────────────────── E2E (Playwright) artifacts ───────────
# Keep the specs/config/README; ignore generated artifacts.
apps/mobile/e2e/screenshots/
# Playwright drops these relative to its cwd (apps/mobile) AND the config dir
# (apps/mobile/e2e); ignore both locations.
apps/mobile/test-results/
apps/mobile/e2e/test-results/
apps/mobile/playwright-report/
apps/mobile/e2e/playwright-report/
# Runtime-generated EXIF/no-EXIF fixtures (built fresh each run by m6.e2e.ts).
apps/mobile/e2e/.fixtures-generated/
**/test-results/
**/playwright-report/
**/playwright/.cache/

# twenty4 mobile (Expo) — environment template. Copy to .env for local runs:
#   cp apps/mobile/.env.example apps/mobile/.env
# (.env is gitignored.) Expo loads .env from THIS app dir (apps/mobile) — it does
# NOT read the monorepo-root .env — so the API URL must live here too.
#
# Only EXPO_PUBLIC_* vars are exposed to the app bundle.

# The machine's LAN/Tailscale IP (e.g. http://100.98.100.117:3000), NOT 127.0.0.1.
# 127.0.0.1 is loopback-only and unreachable from a real device. Must match the
# value in the monorepo-root .env (where the API server reads it). See RUNNING.md.
EXPO_PUBLIC_API_URL=http://100.98.100.117:3000

{
  "expo": {
    "name": "twenty4",
    "slug": "twenty4",
    "version": "0.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "twenty4",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#161210"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.twenty4.app"
    },
    "android": {
      "package": "com.twenty4.app",
      "adaptiveIcon": {
        "backgroundColor": "#161210",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#161210",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200
        }
      ],
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "twenty4 uses your camera to capture photos and videos for your group's daily montage.",
          "microphonePermission": "twenty4 uses your microphone to record audio for videos in your group's daily montage.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "twenty4 accesses your photos so you can import them into your group's daily montage.",
          "cameraPermission": "twenty4 uses your camera to capture photos and videos for your group's daily montage."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}

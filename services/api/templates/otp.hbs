<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Your twenty4 code</title>
  </head>
  <body style="margin:0;padding:0;background:#0b0b0f;font-family:-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#0b0b0f;padding:32px 0;">
      <tr>
        <td align="center">
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="max-width:440px;background:#15151c;border-radius:16px;overflow:hidden;">
            <!-- Ember dark header -->
            <tr>
              <td style="background:#0f0f15;padding:28px 32px;border-bottom:1px solid #23232e;">
                <span style="font-size:20px;font-weight:700;letter-spacing:-0.02em;color:#fafafa;">twenty4</span>
              </td>
            </tr>
            <tr>
              <td style="padding:32px;">
                <h1 style="margin:0 0 8px;font-size:18px;font-weight:600;color:#fafafa;">Your sign-in code</h1>
                <p style="margin:0 0 24px;font-size:14px;line-height:1.6;color:#a1a1ac;">
                  Enter this code to continue. It expires in {{ttlMinutes}} minutes.
                </p>
                <!-- gradient CTA code chip -->
                <div style="text-align:center;margin:0 0 24px;">
                  <span style="display:inline-block;padding:16px 28px;border-radius:12px;background:linear-gradient(135deg,#f97316,#ef4444);font-size:30px;font-weight:700;letter-spacing:0.3em;color:#ffffff;">{{code}}</span>
                </div>
                <p style="margin:0;font-size:12px;line-height:1.6;color:#6b6b78;">
                  If you didn't request this, you can safely ignore this email.
                </p>
              </td>
            </tr>
            <tr>
              <td style="padding:20px 32px;border-top:1px solid #23232e;">
                <p style="margin:0;font-size:11px;color:#5a5a66;">&copy; twenty4</p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>

{
  "name": "@twenty4/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "twenty4 background worker — montage intelligence (EDL build) + the Remotion render half (EDL→MP4). BullMQ-driven, render concurrency=1.",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "harness": "tsx src/validation/harness.ts",
    "smoke": "tsx src/render/__smoke.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@remotion/bundler": "4.0.481",
    "@remotion/renderer": "4.0.481",
    "@twenty4/contracts": "workspace:*",
    "@twenty4/remotion": "workspace:*",
    "bullmq": "^5.34.0",
    "drizzle-orm": "0.45.2",
    "essentia.js": "^0.1.3",
    "execa": "^9.5.0",
    "ioredis": "^5.4.0",
    "postgres": "^3.4.9",
    "remotion": "4.0.481",
    "sharp": "^0.33.5",
    "zod": "^3.23"
  },
  "devDependencies": {
    "@types/node": "^22.19.0",
    "tsx": "^4.22.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
